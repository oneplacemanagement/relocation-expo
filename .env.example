# Environment Variables

# Email Configuration (Choose ONE method)

# Method 1: Resend (Recommended for Vercel)
# Sign up at https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# Method 2: SMTP (Generic email provider)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=The Relocation Expo <noreply@youremaildomain.com>

# Contact Details
CONTACT_TO_EMAIL=info@therelocationexpo.com

# Base URL (Update with your production domain)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Contact form (Web3Forms) — server-side only
WEB3FORMS_ACCESS_KEY=your-web3forms-access-key-here

# Analytics (optional — only loaded if set)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
